# ==============================================================================
# NutriGain - Local Development Environment Variables
# ==============================================================================
# Sử dụng file này khi chạy dev nhẹ:
# - Docker chỉ chạy database: docker compose up -d db
# - Backend chạy local: cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
# - Frontend chạy local: cd frontend && npm run dev
# ==============================================================================

# 1. DATABASE - Kết nối tới MySQL container qua localhost
DATABASE_URL=mysql+pymysql://nutrigain:yennhi2602@localhost:3307/food_recommender

# 2. FRONTEND - API target cho Vite proxy (local dev)
VITE_API_TARGET=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# 3. FEATURE FLAGS
# Tắt CLIP để dev nhẹ hơn (không load model AI nặng)
ENABLE_INGREDIENT_IMAGE_RECOGNITION=false

# 4. RECOMMENDER CONFIGURATION (Optional)
DEBUG_RECOMMENDER=false
REQUIRED_INGREDIENT_COVERAGE=true
FOOD_CATALOG_CACHE_TTL_SECONDS=300
MAX_CANDIDATES_PER_GROUP=100
MAX_TOTAL_CANDIDATES_FOR_SCORING=400
MAX_REQUIRED_INGREDIENTS_PER_PLAN=6
MAX_INGREDIENT_REPLACEMENT_KCAL_DELTA=250
MAX_DAILY_KCAL_DEVIATION_PCT=10
MAX_PROTEIN_DROP_PCT=15


HF_HOME=D:\DOANTOTNGHIEP\NutriGain\hf-cache
HUGGINGFACE_HUB_CACHE=D:\DOANTOTNGHIEP\NutriGain\hf-cache\hub
TRANSFORMERS_CACHE=D:\DOANTOTNGHIEP\NutriGain\hf-cache\transformers
ENABLE_INGREDIENT_IMAGE_RECOGNITION=true