# ==============================================================================
# NutriGain - Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and adjust the values as needed.
# DO NOT commit the actual '.env' file containing secrets to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (MySQL)
# ------------------------------------------------------------------------------
# These variables configure the MySQL database container.
MYSQL_DATABASE=food_recommender
MYSQL_USER=nutrigain
# Production values should be strong, random passwords
MYSQL_PASSWORD=yennhi2602
MYSQL_ROOT_PASSWORD=root
DB_PORT=3307

# ------------------------------------------------------------------------------
# 2. BACKEND CONFIGURATION (FastAPI)
# ------------------------------------------------------------------------------
BACKEND_PORT=8000
APP_ENV=production

# Database URL used by FastAPI backend to connect to MySQL.
# Adjust if you modified MYSQL_USER, MYSQL_PASSWORD, or MYSQL_DATABASE above.
DATABASE_URL=mysql+pymysql://nutrigain:yennhi2602@db:3306/food_recommender

# JWT secret key for security token generation. Change this to a strong 32-character hex key.
# You can generate one using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-secret-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_URL=http://localhost:5173
APP_TIMEZONE=Asia/Ho_Chi_Minh
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=30
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash
AI_PROVIDER=gemini
CLIP_INGREDIENT_THRESHOLD=0.18
DEBUG_RECOMMENDER=false
REQUIRED_INGREDIENT_COVERAGE=true
FOOD_CATALOG_CACHE_TTL_SECONDS=300
MAX_CANDIDATES_PER_GROUP=100
MAX_TOTAL_CANDIDATES_FOR_SCORING=400
MAX_REQUIRED_INGREDIENTS_PER_PLAN=6
MAX_INGREDIENT_REPLACEMENT_KCAL_DELTA=250
MAX_DAILY_KCAL_DEVIATION_PCT=10
MAX_PROTEIN_DROP_PCT=15

# ------------------------------------------------------------------------------
# 3. FRONTEND CONFIGURATION (React/Vite)
# ------------------------------------------------------------------------------
FRONTEND_PORT=5173
# API target used by Vite proxy and frontend API calls.
# Docker uses backend:8000; local dev uses 127.0.0.1:8000.
VITE_API_TARGET=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# ------------------------------------------------------------------------------
# 4. GOOGLE OAUTH CONFIGURATION
# ------------------------------------------------------------------------------
# Set these variables to enable Google Login. 
# Obtain your Client ID from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=400878215222-4hfh99o907afvocnkeu98aivd4kj10jm8.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=400878215222-4hfh99o907afvocnkeu98aivd4kj10jm8.apps.googleusercontent.com

# ------------------------------------------------------------------------------
# 5. PEXELS IMAGE SEARCH
# ------------------------------------------------------------------------------
# Used only by backend/scripts/fetch_pexels_food_images.py.
# Do not hardcode this value in source code.
PEXELS_API_KEY=

# SMTP example (Gmail App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=NutriGain <your_email@gmail.com>
# SMTP_USE_TLS=true
